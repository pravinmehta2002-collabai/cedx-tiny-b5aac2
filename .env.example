# CEDX Tiny Agent Fleet — Environment Configuration
# Copy to .env for local dev (never commit .env)

# Case
CASE_ID=CEDX-B5AAC2

# Where to read seed data from (grader overrides this)
SEED_DIR=/app/seed

# Where to write outputs
OUT_DIR=/app/out

# LLM behavior
# true = 100% offline, use committed /transcripts/*.json (DEFAULT & grading mode)
# false = call real LLM API (requires LLM_API_KEY)
REPLAY_LLM=true

# Real LLM path (only used when REPLAY_LLM=false)
LLM_PROVIDER=openai
LLM_MODEL_CHEAP=gpt-4o-mini
LLM_MODEL_STRONG=gpt-4o
LLM_API_KEY=
LLM_BASE_URL=

# Cost / budget ceilings
MAX_COST_USD_PER_RECORD=0.05
MAX_STEPS_PER_RECORD=6
MAX_LATENCY_MS_PER_RECORD=15000

# Pipeline
PIPELINE_VERSION=0.1.0-tracer